<Page
    x:Class="RadeonTuner.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RadeonTuner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="page_Loaded"
    RequestedTheme="Dark"
    Background="{ThemeResource ApplicationBlackColor}">

    <Grid>
        <Grid x:Name="grid_Main">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Menu -->
            <ListBox x:Name="listbox_Main" Grid.Column="0" SelectionMode="Single" SelectionChanged="listbox_Main_SelectionChanged" Style="{ThemeResource ApplicationListBox}">
                <ListBoxItem x:Name="listboxitem_Tuning">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Tuning.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Tuning"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Fans" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Fans.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Fans"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Graphics" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Graphics.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Graphics"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Display" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Display.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Display"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Multimedia" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Multimedia.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Multimedia"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Settings" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Settings.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Settings"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Information" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Information.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Information"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem x:Name="listboxitem_Exit" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Image HorizontalAlignment="Center" Source="/Assets/Shutdown.png" Width="50" Height="50"/>
                        <TextBlock HorizontalAlignment="Center" Text="Exit"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" CornerRadius="8" Margin="5" Padding="8" Background="{ThemeResource ApplicationDarkGrayColor}">
                    <Grid>
                        <TextBlock Text="RadeonTuner" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal">
                            <!-- Gpu Select -->
                            <ComboBox x:Name="combobox_GpuSelect" IsEnabled="False" Style="{ThemeResource ApplicationComboBox}" SelectionChanged="combobox_GpuSelect_SelectionChanged"/>

                            <!-- Display Select -->
                            <ComboBox x:Name="combobox_DisplaySelect" IsEnabled="False" Margin="10,0,0,0" Style="{ThemeResource ApplicationComboBox}" SelectionChanged="combobox_DisplaySelect_SelectionChanged"/>

                            <!-- Application Select -->
                            <ComboBox x:Name="combobox_AppSelect" IsEnabled="False" Margin="10,0,0,0" Style="{ThemeResource ApplicationComboBox}" SelectionChanged="combobox_AppSelect_SelectionChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Status -->
                <Border x:Name="border_Status" Grid.Row="1" CornerRadius="8" Margin="5" Padding="8" Background="{ThemeResource ApplicationDarkGrayColor}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="textblock_Current_Gpu_Usage" Text="..." Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Core usage"/>
                        <TextBlock x:Name="textblock_Current_Core_Speed" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Core speed"/>
                        <TextBlock x:Name="textblock_Current_Memory_Usage" Text="" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Memory usage"/>
                        <TextBlock x:Name="textblock_Current_Memory_Speed" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Memory speed"/>
                        <TextBlock x:Name="textblock_Current_Power_Wattage" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Power wattage"/>
                        <TextBlock x:Name="textblock_Current_Power_Voltage" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Power voltage"/>
                        <TextBlock x:Name="textblock_Current_Fan_Speed" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Fan speed"/>
                        <TextBlock x:Name="textblock_Current_Temp_Core" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Core temperature"/>
                        <TextBlock x:Name="textblock_Current_Temp_Memory" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Memory temperature"/>
                        <TextBlock x:Name="textblock_Current_Temp_Hotspot" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Hotspot temperature"/>
                        <TextBlock x:Name="textblock_Current_Temp_Intake" Margin="0,0,8,0" FontSize="18" ToolTipService.ToolTip="Intake temperature"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <VariableSizedWrapGrid x:Name="stackpanel_Tuning_Buttons" Grid.Row="2" ItemWidth="105" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Tuning_Apply" Click="button_Tuning_Apply_Click" Content="Apply" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Apply tuning and fans settings."/>
                    <Button x:Name="button_Tuning_Reset" Click="button_Tuning_Reset_Click" Content="Reset" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Reset tuning and fans settings to it's defaults."/>
                    <Button x:Name="button_Tuning_Import" Click="button_Tuning_Import_Click" Content="Import" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Import tuning and fans settings from file, the settings do not automatically get applied."/>
                    <Button x:Name="button_Tuning_Export" Click="button_Tuning_Export_Click" Content="Export" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Export current tuning and fans settings to file."/>
                </VariableSizedWrapGrid>
                <VariableSizedWrapGrid x:Name="stackpanel_Fan_Buttons" Grid.Row="2" ItemWidth="105" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Fan_Apply" Click="button_Tuning_Apply_Click" Content="Apply" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Apply tuning and fans settings."/>
                    <Button x:Name="button_Fan_Reset" Click="button_Tuning_Reset_Click" Content="Reset" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Reset tuning and fans settings to it's defaults."/>
                    <Button x:Name="button_Fan_Import" Click="button_Tuning_Import_Click" Content="Import" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Import tuning and fans settings from file, the settings do not automatically get applied."/>
                    <Button x:Name="button_Fan_Export" Click="button_Tuning_Export_Click" Content="Export" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Export current tuning and fans settings to file."/>
                </VariableSizedWrapGrid>
                <VariableSizedWrapGrid x:Name="stackpanel_Graphics_Buttons" Grid.Row="2" ItemWidth="125" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Graphics_AddExe" Click="button_Graphics_AddExe_Click" Content="Add Executable" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Add executable as application."/>
                    <Button x:Name="button_Graphics_AddProcess" Click="button_Graphics_AddProcess_Click" Content="Add Process" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Add process as application."/>
                    <Button x:Name="button_Graphics_Remove" Click="button_Graphics_Remove_Click" Content="Remove App" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Remove selected application."/>
                    <Button x:Name="button_Graphics_Reset_Settings" Click="button_Graphics_Reset_Settings_Click" Content="Reset Settings" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Reset graphics settings to it's defaults."/>
                    <Button x:Name="button_Graphics_Import" Click="button_Graphics_Import_Click" Content="Import Settings" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Import graphics settings from file."/>
                    <Button x:Name="button_Graphics_Export" Click="button_Graphics_Export_Click" Content="Export Settings" Width="120" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Export current graphics settings to file."/>
                    <Button x:Name="button_Graphics_Clear_ShaderCache" Click="button_Graphics_Clear_ShaderCache_Click" Content="Clear Shaders" Width="120" ToolTipService.ToolTip="Clear contents of the disk-based shader cache." Style="{ThemeResource ApplicationButton}"/>
                </VariableSizedWrapGrid>
                <VariableSizedWrapGrid x:Name="stackpanel_Display_Buttons" Grid.Row="2" ItemWidth="105" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Display_Reset" Click="button_Display_Reset_Click" Content="Reset" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Reset display color settings to it's defaults."/>
                    <Button x:Name="button_Display_Import" Click="button_Display_Import_Click" Content="Import" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Import display color settings from file."/>
                    <Button x:Name="button_Display_Export" Click="button_Display_Export_Click" Content="Export" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Export current display color settings to file."/>
                </VariableSizedWrapGrid>
                <VariableSizedWrapGrid x:Name="stackpanel_Multimedia_Buttons" Grid.Row="2" ItemWidth="105" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Multimedia_Reset" Click="button_Multimedia_Reset_Click" Content="Reset" Width="100" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Reset multimedia settings to it's defaults."/>
                </VariableSizedWrapGrid>
                <VariableSizedWrapGrid x:Name="stackpanel_Information_Buttons" Grid.Row="2" ItemWidth="155" ItemHeight="42" Margin="5,0,5,0" Orientation="Horizontal">
                    <Button x:Name="button_Website_Project" Content="Visit Project Website" Width="150" Style="{ThemeResource ApplicationButton}" Click="button_Website_Project_Click"/>
                    <Button x:Name="button_Website_Donation" Content="Open Donation Page" Width="150" Style="{ThemeResource ApplicationButton}" Click="button_Website_Donation_Click"/>
                    <Button x:Name="button_Fps_Overlayer" Content="Get FpsOverlayer" Width="150" Style="{ThemeResource ApplicationButton}" Click="button_Fps_Overlayer_Click"/>
                    <Button x:Name="button_Check_Update" Content="Check For Update" Width="150" Style="{ThemeResource ApplicationButton}" Click="button_Check_Update_Click"/>
                </VariableSizedWrapGrid>

                <!-- Main -->
                <ScrollViewer Grid.Row="3" Margin="5,0,5,0" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,10,10">
                        <!-- Graphics -->
                        <StackPanel x:Name="stackpanel_Graphics" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Margin="5,0,20,0" Text="FSR Options" FontSize="20" FontWeight="Medium"/>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <TextBlock x:Name="textblock_GraphicsOptions_Name" FontSize="20" FontWeight="Medium"/>
                                    <TextBlock x:Name="textblock_GraphicsOptions_Details" Margin="6,0,0,0" FontSize="20" Foreground="{StaticResource ApplicationDimGrayBrush}"/>
                                    <Image Source="/Assets/Warning.png" Margin="6,3,0,0" Width="24" Height="24" ToolTipService.ToolTip="* Changing graphics options below might require an application restart to take affect.&#10;&#10;* Some settings like 'Fluid Motion Frames' and 'Super Resolution' are not available because they don't work on 'Minimal' and 'Driver Only' software type installations."/>
                                </StackPanel>
                            </Grid>

                            <!-- Radeon FSR Options -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- FSR Latency Reduction -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="FSR Latency Reduction (Anti-Lag) helps reduce input lag in GPU-limited cases by controlling the pace of the CPU work to ensure it doesn't get too far ahead of the GPU, enabling this setting may lead to minimal frame rate loss."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting does not work on OpenGL applications.&#10;&#10;* This setting cannot be used when 'Radeon Chill' is enabled."/>
                                        <Image x:Name="image_FsrLatencyReduction_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_FsrLatencyReduction" Margin="10,0,0,0" OffContent="FSR Latency Reduction" OnContent="FSR Latency Reduction" Toggled="toggleswitch_FsrLatencyReduction_Toggled"/>
                                    </StackPanel>

                                    <!-- FSR Multi Frame Generation Ratio -->
                                    <StackPanel x:Name="stackpanel_MultiFrameGenerationRatio">
                                        <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose the frame rate multipier used by FSR Multi Frame Generation, a higher multiplier increases smoothness but may cause more graphical glitches based on the intensity of in-game movement."/>
                                            <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards.&#10;&#10;* This setting only works on white listed applications."/>
                                            <TextBlock Text="FSR Multi Frame Generation Ratio" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox x:Name="combobox_MultiFrameGenerationRatio" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_MultiFrameGenerationRatio_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="FSR Override" FontSize="20" FontWeight="Medium"/>

                            <!-- Radeon FSR Override -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- FSR Upscaling Override -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Overrides the application FSR feature with the latest version provided by the driver, allowing the driver for example to upgrade FSR3 to FSR4 or newer."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA3 or newer graphic cards and requires an application to have at least FSR 3.1.0 support and external FSR dll file.&#10;&#10;* Some applications use a preset FSR version number text in the settings menu so even when the FSR Override is active and working you may still see the old version number text."/>
                                        <Image x:Name="image_FsrOverrideUpscaling_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_FsrOverrideUpscaling" Margin="10,0,0,0" OffContent="FSR Upscaling Override" OnContent="FSR Upscaling Override" Toggled="toggleswitch_FsrOverrideUpscaling_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,5,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- FSR Frame Generation Override -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Overrides the application FSR feature with the latest version provided by the driver, allowing the driver for example to upgrade FSR3 to FSR4 or newer."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards and requires an application to have at least FSR 3.1.4 support and external FSR dll file.&#10;&#10;* Some applications use a preset FSR version number text in the settings menu so even when the FSR Override is active and working you may still see the old version number text."/>
                                        <Image x:Name="image_FsrOverrideFrameGeneration_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_FsrOverrideFrameGeneration" Margin="10,0,0,0" OffContent="FSR Frame Generation Override" OnContent="FSR Frame Generation Override" Toggled="toggleswitch_FsrOverrideFrameGeneration_Toggled"/>
                                    </StackPanel>

                                    <!-- FSR Multi Frame Generation Override -->
                                    <StackPanel x:Name="stackpanel_FsrOverrideMultiFrameGeneration">
                                        <Border Margin="0,5,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Overrides the application FSR feature with the latest version provided by the driver, allowing the driver for example to upgrade FSR3 to FSR4 or newer."/>
                                            <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards and requires an application to have at least FSR 3.1.6 support and external FSR dll file.&#10;&#10;* Some applications use a preset FSR version number text in the settings menu so even when the FSR Override is active and working you may still see the old version number text."/>
                                            <Image x:Name="image_FsrOverrideMultiFrameGeneration_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                            <ToggleSwitch x:Name="toggleswitch_FsrOverrideMultiFrameGeneration" Margin="10,0,0,0" OffContent="FSR Multi Frame Generation Override" OnContent="FSR Multi Frame Generation Override" Toggled="toggleswitch_FsrOverrideMultiFrameGeneration_Toggled"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- FSR Ray Regeneration Denoiser Override -->
                                    <StackPanel x:Name="stackpanel_FsrOverrideRayRegeneration">
                                        <Border Margin="0,5,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Overrides the application FSR feature with the latest version provided by the driver, allowing the driver for example to upgrade FSR3 to FSR4 or newer."/>
                                            <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards and requires an application to have at least FSR 3.1.6 support and external FSR dll file.&#10;&#10;* Some applications use a preset FSR version number text in the settings menu so even when the FSR Override is active and working you may still see the old version number text."/>
                                            <Image x:Name="image_FsrOverrideRayRegeneration_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                            <ToggleSwitch x:Name="toggleswitch_FsrOverrideRayRegeneration" Margin="10,0,0,0" OffContent="FSR Ray Regeneration Denoiser Override" OnContent="FSR Ray Regeneration Denoiser Override" Toggled="toggleswitch_FsrOverrideRayRegeneration_Toggled"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- FSR Neural Radiance Caching Override -->
                                    <StackPanel x:Name="stackpanel_FsrOverrideNeuralRadianceCaching">
                                        <Border Margin="0,5,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Overrides the application FSR feature with the latest version provided by the driver, allowing the driver for example to upgrade FSR3 to FSR4 or newer."/>
                                            <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards and requires an application to have at least FSR 3.1.6 support and external FSR dll file.&#10;&#10;* Some applications use a preset FSR version number text in the settings menu so even when the FSR Override is active and working you may still see the old version number text."/>
                                            <Image x:Name="image_FsrOverrideNeuralRadianceCaching_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                            <ToggleSwitch x:Name="toggleswitch_FsrOverrideNeuralRadianceCaching" Margin="10,0,0,0" OffContent="FSR Neural Radiance Caching Override" OnContent="FSR Neural Radiance Caching Override" Toggled="toggleswitch_FsrOverrideNeuralRadianceCaching_Toggled"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- FSR Override Library -->
                                    <Border Margin="0,5,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Manually choose the FSR Library (dll) file that gets used when overriding FSR features in applications."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* When playing online games make sure to use an officially signed version by AMD to prevent getting into trouble with the games anti-cheat protection.&#10;&#10;* This setting only works on RDNA3 or newer graphic cards."/>
                                        <TextBlock Text="FSR Override Library" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="textblock_FsrDllVersion" Text="?.?.?.?" Foreground="{StaticResource ApplicationDimGrayBrush}" Margin="5,0,0,0" VerticalAlignment="Center"/>

                                    </StackPanel>
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <Button x:Name="button_FsrDllLoadPath_Set" Content="Set" Style="{ThemeResource ApplicationButton}" Click="button_FsrDllLoadPath_Set_Click"/>
                                        <Button x:Name="button_FsrDllLoadPath_Default" Content="Default" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" Click="button_FsrDllLoadPath_Default_Click"/>
                                        <TextBlock x:Name="textblock_FsrDllLoadPath" Text="..." Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- FSR Over-The-Air Updates -->
                                    <StackPanel x:Name="stackpanel_FsrOtaUpdates">
                                        <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose the source for AMD FSR Over-The-Air (OTA) updates. Use the driver's built-in package or receive newer builds Over-The-Air from AMD Install Manager."/>
                                            <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA3 or newer graphic cards."/>
                                            <TextBlock Text="FSR Over-The-Air Updates" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <ComboBox x:Name="combobox_FsrOtaUpdates" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_FsrOtaUpdates_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel x:Name="stackpanel_FluidMotion_Options">
                                <TextBlock Margin="5,10,0,0" Text="Fluid Motion Options" FontSize="20" FontWeight="Medium"/>

                                <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <!-- Fluid Motion Frames Enabled -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Fluid Motion Frames is a frame generation feature to boost the displayed frames beyond the in-game limit, resulting in a smoother experience.&#10;&#10;As this feature may introduce additional latency in games, it is recommended to utilize Radeon Anti-Lag for optimal performance."/>
                                                <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works when using exclusive full-screen mode.&#10;&#10;* This setting only works on applications using OpenGL, Vulkan and DirectX 11 or 12.&#10;&#10;* This setting only works on RDNA2 or newer graphic cards.&#10;&#10;* This setting only works when using the 'Default' driver software installation type and needs Adrenalin Software to be running in the background and also requires an application to be added to the game library."/>
                                                <ToggleSwitch x:Name="toggleswitch_FrameGenEnabled" Margin="10,0,0,0" OffContent="Radeon Fluid Motion Frames" OnContent="Radeon Fluid Motion Frames" Toggled="toggleswitch_FrameGenEnabled_Toggled"/>
                                            </StackPanel>

                                            <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjusts Fluid Motion Frames search mode to respond better to high-motion scenes and improve smoothness."/>
                                                    <TextBlock Margin="10,0,0,0" Text="Search Mode" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ComboBox x:Name="combobox_FrameGenSearchMode" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_FrameGenSearchMode_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                            </StackPanel>

                                            <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Reduces the potential performance overhead of Fluid Motion but may lower the image quality during high-motion scenes."/>
                                                    <TextBlock Margin="10,0,0,0" Text="Performance Mode" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ComboBox x:Name="combobox_FrameGenPerfMode" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_FrameGenPerfMode_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                            </StackPanel>

                                            <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Configure AFMF's response to fast motion to either use a 'Repeat Frame' to maintain image quality or 'Blended Frame' for smoother motion."/>
                                                    <TextBlock Margin="10,0,0,0" Text="Fast Motion Response" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ComboBox x:Name="combobox_FrameGenResponseMode" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_FrameGenResponseMode_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                            </StackPanel>

                                            <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjusts the Fluid Motion Frames algorithm used."/>
                                                    <TextBlock Margin="10,0,0,0" Text="Algorithm" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ComboBox x:Name="combobox_FrameGenAlgorithm" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_FrameGenAlgorithm_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <TextBlock Margin="5,10,0,0" Text="Limiter Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Radeon Chill -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Radeon Chill conserves power and reduces heat by adjusting the frame rate based on the intensity of in-game movement."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting does not work on OpenGL applications.&#10;&#10;* This setting cannot be used when 'FSR Latency Reduction' is enabled."/>
                                        <Image x:Name="image_RadeonChill_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonChill" Margin="10,0,0,0" OffContent="Radeon Chill" OnContent="Radeon Chill" Toggled="toggleswitch_RadeonChill_Toggled"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="button_RadeonChill_Link" Opacity="0.50" Click="button_RadeonChill_Link_Click" Style="{ThemeResource ApplicationButtonImage}" Margin="0,0,10,0">
                                            <Image Source="/Assets/Link.png" Width="24" Height="24" ToolTipService.ToolTip="Match minimum and maximum when changing Radeon Chill to limit frames per second instead of adjusting."/>
                                        </Button>
                                        <TextBlock Text="Min" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_RadeonChill_Min" Margin="5,0,0,0" Text="{Binding ElementName=slider_RadeonChill_Min, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_RadeonChill_Min" Width="150" Margin="10,0,10,0" ValueChanged="slider_RadeonChill_Min_ValueChanged"/>
                                        <TextBlock Text="Max" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_RadeonChill_Max" Margin="5,0,0,0" Text="{Binding ElementName=slider_RadeonChill_Max, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_RadeonChill_Max" Width="150" Margin="10,0,10,0" ValueChanged="slider_RadeonChill_Max_ValueChanged"/>
                                        <TextBlock Text="FPS" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Frame Rate Target Control -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Frame Rate Target Control sets an user-defined target maximum frame rate to reduce power consumption."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works when using exclusive full-screen mode."/>
                                        <ToggleSwitch x:Name="toggleswitch_Frtc" Margin="10,0,0,0" OffContent="Frame Rate Target Control" OnContent="Frame Rate Target Control" Toggled="toggleswitch_Frtc_Toggled"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Maximum" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_Frtc_Fps" Margin="5,0,0,0" Text="{Binding ElementName=slider_Frtc_Fps, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_Frtc_Fps" Width="150" Margin="10,0,10,0" ValueChanged="slider_Frtc_Fps_ValueChanged"/>
                                        <TextBlock Text="FPS" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Radeon Boost -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Radeon Boost dynamically reduces resolution during motion to improve performance with minimal perceptible impact on image quality."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on white listed applications."/>
                                        <Image x:Name="image_RadeonBoost_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonBoost" Margin="10,0,0,0" OffContent="Radeon Boost" OnContent="Radeon Boost" Toggled="toggleswitch_RadeonBoost_Toggled"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Min. Resolution" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_RadeonBoost_MinRes" Margin="5,0,0,0" Text="{Binding ElementName=slider_RadeonBoost_MinRes, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_RadeonBoost_MinRes" Width="150" Margin="10,0,10,0" ValueChanged="slider_RadeonBoost_MinRes_ValueChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="Sharpening Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Radeon Image Sharpening 1 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Radeon Image Sharpening restores clarity softened by other effects to in-game visuals, select productivity and media applications."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA3 or older graphic cards and in application profiles.&#10;&#10;* DirectX 9 applications are only supported on RDNA and newer graphic cards.&#10;&#10;* This setting does not work with HDR enabled and OpenGL applications."/>
                                        <Image x:Name="image_RadeonImageSharpening1_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonImageSharpening1" Margin="10,0,0,0" OffContent="Radeon Image Sharpening 1" OnContent="Radeon Image Sharpening 1" Toggled="toggleswitch_RadeonImageSharpening1_Toggled"/>
                                    </StackPanel>

                                    <!-- Radeon Image Sharpening 1 Sharpness -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Sharpening" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_RadeonImageSharpening1_Sharpening" Margin="5,0,0,0" Text="{Binding ElementName=slider_RadeonImageSharpening1_Sharpening, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_RadeonImageSharpening1_Sharpening" Width="150" Margin="10,0,10,0" ValueChanged="slider_RadeonImageSharpening1_Sharpening_ValueChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Radeon Image Sharpening 2 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Radeon Image Sharpening restores clarity softened by other effects to in-game visuals, select productivity and media applications."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works on RDNA4 or newer graphic cards.&#10;&#10;* This setting only works when using full-screen mode, unless you also enable the 'Sharpen Desktop' option."/>
                                        <Image x:Name="image_RadeonImageSharpening2_Status" Visibility="Collapsed" Source="/Assets/StatusEnabled.png" Width="24" Height="24" ToolTipService.ToolTip="..."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonImageSharpening2" Margin="10,0,0,0" OffContent="Radeon Image Sharpening 2" OnContent="Radeon Image Sharpening 2" Toggled="toggleswitch_RadeonImageSharpening2_Toggled"/>
                                    </StackPanel>

                                    <!-- Radeon Image Sharpening 2 Desktop -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Apply sharpening to your desktop and applications, including windowed applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonImageSharpening2_Desktop" Margin="10,0,0,0" OffContent="Sharpen Desktop" OnContent="Sharpen Desktop" Toggled="toggleswitch_RadeonImageSharpening2_Desktop_Toggled"/>
                                    </StackPanel>

                                    <!-- Radeon Image Sharpening 2 Sharpness -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Sharpening" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_RadeonImageSharpening2_Sharpening" Margin="5,0,0,0" Text="{Binding ElementName=slider_RadeonImageSharpening2_Sharpening, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_RadeonImageSharpening2_Sharpening" Width="150" Margin="10,0,10,0" ValueChanged="slider_RadeonImageSharpening2_Sharpening_ValueChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="Vertical Refresh Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Vertical Refresh -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Vertical refresh synchronizes the transition to a new frame of animation with the display update so no tearing is visible between frames.&#10;&#10;* Limits the frame rate at the display's refresh rate."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting may only work when using exclusive full-screen mode depending on the renderer pipeline."/>
                                        <TextBlock Margin="10,0,0,0" Text="Wait for Vertical Refresh" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_VerticalRefresh" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_VerticalRefresh_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Radeon Enhanced Sync -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Radeon Enhanced Sync synchronizes the transition to a new frame of animation with the display refresh rate at a low latency, so minimal tearing is visible between frames.&#10;&#10;* Does not limit the frame rate at the display's refresh rate."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting may only work when using exclusive full-screen mode depending on the renderer pipeline.&#10;&#10;* When an application does not support 'Enhanced Sync' it will fallback and use the 'Vertical Sync' setting."/>
                                        <ToggleSwitch x:Name="toggleswitch_RadeonEnhancedSync" Margin="10,0,0,0" OffContent="Radeon Enhanced Sync" OnContent="Radeon Enhanced Sync" Toggled="toggleswitch_RadeonEnhancedSync_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- OpenGL Triple Buffering -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Alternative vertical refresh mode exclusively for OpenGL applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_OpenGLTripleBuffering" Margin="10,0,0,0" OffContent="OpenGL Triple Buffering" OnContent="OpenGL Triple Buffering" Toggled="toggleswitch_OpenGLTripleBuffering_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="Anti-Aliasing Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Anti-Aliasing Override -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Anti-aliasing improves image quality by smoothing jagged edges at the cost of some performance and video memory usage."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Anti-Aliasing Override, Method, Level and EQAA only works on DirectX 9 (and older) and some OpenGL applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_AntiAliasingOverride" Margin="10,0,0,0" OffContent="Anti-Aliasing Override" OnContent="Anti-Aliasing Override" Toggled="toggleswitch_AntiAliasingOverride_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Anti-Aliasing Method -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose the method used to smooth object edges, more sampling improves quality but reduces performance.&#10;&#10;* Multisampling (MSAA) targets only object edges.&#10;&#10;* Adaptive Multisampling (Adaptive MSAA) smooths both edges and transparent textures.&#10;&#10;* Supersampling (SSAA/FSAA) covers every pixel for excellent quality but a substantial performance cost."/>
                                        <TextBlock Text="Anti-Aliasing Method" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_AntiAliasingMethod" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_AntiAliasingMethod_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Anti-Aliasing Level -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose the number of samples used for edge anti-aliasing, higher sample counts improve image quality at the cost of performance."/>
                                        <TextBlock Text="Anti-Aliasing Level" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_AntiAliasingLevel" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_AntiAliasingLevel_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Enhanced Quality Anti-Aliasing -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Enhanced Quality Anti-Aliasing (EQAA) is an anti-aliasing technology that offers advanced smoothing of aliased edges without requiring additional video memory but comes with a small additional performance cost."/>
                                        <ToggleSwitch x:Name="toggleswitch_EnhancedQualityAntiAliasing" Margin="10,0,0,0" OffContent="Enhanced Quality Anti-Aliasing" OnContent="Enhanced Quality Anti-Aliasing" Toggled="toggleswitch_EnhancedQualityAntiAliasing_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Morphological Anti-Aliasing -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Morphological Anti-Aliasing (MLAA) is an edge-smoothing technique with minimal performance overhead."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting only works when using exclusive full-screen mode.&#10;&#10;* This setting only works on DirectX 9 applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_MorphologicalAntiAliasing" Margin="10,0,0,0" OffContent="Morphological Anti-Aliasing" OnContent="Morphological Anti-Aliasing" Toggled="toggleswitch_MorphologicalAntiAliasing_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="Texture Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Anisotropic Texture Filtering Override -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Anisotropic filtering improves texture quality in most 3D applications on surfaces that appear far away or at odd angles - such as roads or trees - at the cost of some frame rate performance."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Some applications require to have texture filtering type set to 'Trilinear' or 'Bilinear' to make the override work.&#10;&#10;* This setting does not work on DirectX 12 and Vulkan applications."/>
                                        <TextBlock Text="Anisotropic Texture Filtering Override" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_AnisotropicTextureFiltering_Level" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_AnisotropicTextureFiltering_Level_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                </StackPanel>
                            </Border>

                            <!-- Texture Filtering Quality -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Controls the optimization point for texture filtering, 'Standard' is typically the best mix of image quality and performance."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Requires a texture filtering type like 'Anisotropic' to be enabled in an application to work.&#10;&#10;* This setting does not work on DirectX 12 and Vulkan applications."/>
                                        <TextBlock Text="Texture Filtering Quality" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_TextureFilteringQuality" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_TextureFilteringQuality_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                </StackPanel>
                            </Border>

                            <!-- Surface Format Optimization -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Allows the driver to override the application and choose a more optimal texture format to improve performance and lower video memory usage, typically has a minimal impact on image quality."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting does not work on DirectX 12 and Vulkan applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_SurfaceFormatOptimization" Margin="10,0,0,0" OffContent="Surface Format Optimization" OnContent="Surface Format Optimization" Toggled="toggleswitch_SurfaceFormatOptimization_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- OpenGL 10-Bit Pixel Format -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Enables 10-Bit OpenGL texture support for compatible displays and applications."/>
                                    <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* System restart required to take effect."/>
                                    <ToggleSwitch x:Name="toggleswitch_OpenGL10BitPixelFormat" Margin="10,0,0,0" OffContent="OpenGL 10-Bit Pixel Format" OnContent="OpenGL 10-Bit Pixel Format" Toggled="toggleswitch_OpenGL10BitPixelFormat_Toggled"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="5,10,0,0" Text="Tessellation Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Tessellation Mode -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Tessellation adjusts the number of polygons used to render objects with enhanced detail, at the cost of some frame rate performance."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Some applications require to have 'Tessellation' enabled to make the override work.&#10;&#10;* Tessellation Mode and Level only works on DirectX 11 applications."/>
                                        <TextBlock Text="Tessellation Mode" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_Tessellation_Mode" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_Tessellation_Mode_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Tessellation Level -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose the number of polygons to be produced during the tessellation of objects, setting a limit can prevent excessive tessellation with little or no benefit in image quality and performance."/>
                                        <TextBlock Text="Tessellation Level" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_Tessellation_Level" Margin="0,5,0,0" Width="260" SelectionChanged="combobox_Tessellation_Level_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Tuning -->
                        <StackPanel x:Name="stackpanel_Tuning" Visibility="Collapsed">
                            <!-- Keep Active -->
                            <TextBlock Text="Keep Active" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Reapply your set tuning and fans settings when those have been reset to defaults by the GPU driver due to an unexpected system failure or other reason."/>
                                    <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Make sure you are using stable and well tested tuning and fan settings before enabling Keep Active.&#10;&#10;* Keep active only works when RadeonTuner is running."/>
                                    <ToggleSwitch x:Name="toggleswitch_KeepActive" Width="130" Margin="10,0,0,0" OffContent="Keep Active" OnContent="Keep Active"/>
                                    <TextBlock Margin="5,0,0,0" x:Name="textblock_KeepActive_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- GPU Tuning -->
                            <TextBlock Text="GPU Tuning" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the minimum graphics frequency."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Setting the minimum frequency close to the maximum frequency can lead to a big performance loss so make sure to find the sweet spot by testing the performance or leave it at default."/>
                                        <TextBlock Margin="10,0,0,0" Text="Minimum Frequency" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Core_Min_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Core_Min" Text="{Binding ElementName=slider_Core_Min, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Core_Min" ValueChanged="slider_Core_Min_ValueChanged" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the maximum allowable graphics frequency."/>
                                        <TextBlock x:Name="textblock_Core_Max" Margin="10,0,0,0" Text="Maximum Frequency" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Core_Max_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Core_Max" Text="{Binding ElementName=slider_Core_Max, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Core_Max" ValueChanged="slider_Core_Max_ValueChanged" Margin="10,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Memory Tuning -->
                            <TextBlock Text="Memory Tuning" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the memory timing profile, faster memory latency timings increases performance."/>
                                        <TextBlock Margin="10,0,0,0" Text="Memory Timing" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Memory_Timing_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="combobox_Memory_Timing" Margin="0,5,0,0" Width="300" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the maximum allowable memory frequency."/>
                                        <TextBlock Margin="10,0,0,0" Text="Maximum Frequency" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Memory_Max_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Memory_Max" Text="{Binding ElementName=slider_Memory_Max, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Memory_Max" Margin="10,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Power Tuning -->
                            <TextBlock Text="Power Tuning" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the maximum allowable power consumption of the GPU, a higher power limit increases performance."/>
                                        <TextBlock Margin="10,0,0,0" Text="Power Limit" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Power_Limit_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Power_Limit" Text="{Binding ElementName=slider_Power_Limit, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Power_Limit" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Grid x:Name="grid_Power_Limit_PB" Margin="0,10,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Height="28" Width="28" Source="/Assets/PowerBoost.png" ToolTipService.ToolTip="Used when Power Boost is enabled."/>
                                        <TextBox Grid.Column="1" x:Name="textbox_Power_Limit_PB" Margin="5,0,0,0" Text="{Binding ElementName=slider_Power_Limit_PB, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="2" x:Name="slider_Power_Limit_PB" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the voltage offset across the entire clock range of the GPU, a lower voltage increases performance."/>
                                        <TextBlock x:Name="textblock_Power_Voltage" Margin="10,0,0,0" Text="Voltage" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Power_Voltage_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Power_Voltage" Text="{Binding ElementName=slider_Power_Voltage, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Power_Voltage" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Grid x:Name="grid_Power_Voltage_PB" Margin="0,5,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Height="28" Width="28" Source="/Assets/PowerBoost.png" ToolTipService.ToolTip="Used when Power Boost is enabled."/>
                                        <TextBox Grid.Column="1" x:Name="textbox_Power_Voltage_PB" Margin="5,0,0,0" Text="{Binding ElementName=slider_Power_Voltage_PB, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="2" x:Name="slider_Power_Voltage_PB" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjust the Thermal Design Current (TDC) limit of a GPU, a higher TDC limit increases performance."/>
                                        <TextBlock Margin="10,0,0,0" Text="TDC Limit" VerticalAlignment="Center"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Power_TDC_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Power_TDC" Text="{Binding ElementName=slider_Power_TDC, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Power_TDC" Margin="10,0,0,0"/>
                                    </Grid>

                                    <Grid x:Name="grid_Power_TDC_PB" Margin="0,5,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Height="28" Width="28" Source="/Assets/PowerBoost.png" ToolTipService.ToolTip="Used when Power Boost is enabled."/>
                                        <TextBox Grid.Column="1" x:Name="textbox_Power_TDC_PB" Margin="5,0,0,0" Text="{Binding ElementName=slider_Power_TDC_PB, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="2" x:Name="slider_Power_TDC_PB" Margin="10,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Power Boost -->
                            <TextBlock Text="Power Boost" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Power Boost allows you to automatically adjust your GPU's power for high demanding applications.&#10;&#10;When one of the applications in the list below is running the Power Boost values will be applied and restored back to normal when no longer running."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* It may take a few seconds before Power Boost is activated when launching an application.&#10;&#10;* Power Boost only works when RadeonTuner is running."/>
                                        <ToggleSwitch x:Name="toggleswitch_PowerBoost" Width="135" Margin="10,0,0,0" OffContent="Power Boost" OnContent="Power Boost" Toggled="toggleswitch_PowerBoost_Toggled"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_PowerBoost_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <ComboBox x:Name="combobox_PowerBoost_Applications" Width="300" Style="{ThemeResource ApplicationComboBox}"/>
                                        <Button x:Name="button_PowerBoost_AddExe" Content="Add executable" Click="button_PowerBoost_AddExe_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Add executable file as application."/>
                                        <Button x:Name="button_PowerBoost_Remove" Content="Remove" Click="button_PowerBoost_Remove_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Remove selected application."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Fans -->
                        <StackPanel x:Name="stackpanel_Fans" Visibility="Collapsed">
                            <TextBlock Text="Fan Speed and Temperature Options" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Let the driver take control over your GPU fans which allows you to set a custom fan curve, when disabled the GPU will manage the fans as set in the bios."/>
                                        <ToggleSwitch x:Name="toggleswitch_Fan_Control" Width="128" Margin="10,0,0,0" OffContent="Fan Control" OnContent="Fan Control" Toggled="toggleswitch_Fan_Control_Toggled"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Control_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Turns the fans off when the GPU does not need cooling to reduce noise levels and improve fan durability."/>
                                        <ToggleSwitch x:Name="toggleswitch_Fan_Zero_Rpm" Width="185" Margin="10,0,0,0" OffContent="Fan Zero RPM Mode" OnContent="Fan Zero RPM Mode" Toggled="toggleswitch_Fan_Zero_Rpm_Toggled"/>
                                        <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Zero_Rpm_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid x:Name="grid_Fan_Graph" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.Row="0" BorderBrush="{ThemeResource ApplicationWhiteColor}" BorderThickness="2" CornerRadius="5">
                                    <Grid>
                                        <Grid Margin="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Line Margin="0,25,0,0" X1="500" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>
                                            <Line Margin="0,50,0,0" X1="500" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>
                                            <Line Margin="0,75,0,0" X1="500" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>
                                            <Line Margin="125,0,0,0" Y1="100" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>
                                            <Line Margin="250,0,0,0" Y1="100" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>
                                            <Line Margin="375,0,0,0" Y1="100" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeThickness="1"/>

                                            <Line x:Name="grid_Fan_Zero_Rpm_Line_Gpu" Visibility="Collapsed" Margin="275,0,0,0" Y1="99" Stroke="{ThemeResource ApplicationDimGrayColor}" StrokeDashArray="3" StrokeDashCap="Round" StrokeThickness="3"/>
                                            <Line x:Name="grid_Fan_Zero_Rpm_Line_Profile" Visibility="Collapsed" Margin="275,0,0,0" Y1="99" Stroke="{ThemeResource SystemAccentColor}" StrokeDashArray="3" StrokeDashCap="Round" StrokeThickness="3"/>
                                            <Polyline x:Name="polyline_Fan_Lines_Gpu" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeDashCap="Round" Stroke="{StaticResource ApplicationDimGrayColor}" StrokeThickness="2"/>
                                            <Polyline x:Name="polyline_Fan_Lines_Profile" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeDashCap="Round" Stroke="{StaticResource SystemAccentColor}" StrokeThickness="2"/>
                                        </Grid>
                                        <Grid x:Name="grid_Fan_Dots" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Stretch">
                                    <TextBlock Text="0% Fan speed" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="50% Fan speed" VerticalAlignment="Center"/>
                                    <TextBlock Text="100% Fan speed" VerticalAlignment="Top"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,5,0,0" HorizontalAlignment="Stretch">
                                    <TextBlock Text="0°C" HorizontalAlignment="Left"/>
                                    <TextBlock Text="50°C" HorizontalAlignment="Center"/>
                                    <TextBlock Text="100°C" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>

                            <VariableSizedWrapGrid Orientation="Horizontal" Margin="-5,5,0,0">
                                <Border Width="280" Margin="5" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan Curve 1" FontSize="16" FontWeight="Medium"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_0_Speed_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_0_Temp_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Speed_0" Text="{Binding ElementName=slider_Fan_Speed_0, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="%" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Speed_0" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Temp_0" Text="{Binding ElementName=slider_Fan_Temp_0, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="°C" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Temp_0" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Width="280" Margin="5" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan Curve 2" FontSize="16" FontWeight="Medium"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_1_Speed_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_1_Temp_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Speed_1" Text="{Binding ElementName=slider_Fan_Speed_1, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="%" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Speed_1" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Temp_1" Text="{Binding ElementName=slider_Fan_Temp_1, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="°C" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Temp_1" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Width="280" Margin="5" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan Curve 3" FontSize="16" FontWeight="Medium"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_2_Speed_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_2_Temp_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Speed_2" Text="{Binding ElementName=slider_Fan_Speed_2, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="%" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Speed_2" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Temp_2" Text="{Binding ElementName=slider_Fan_Temp_2, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="°C" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Temp_2" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Width="280" Margin="5" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan Curve 4" FontSize="16" FontWeight="Medium"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_3_Speed_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_3_Temp_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Speed_3" Text="{Binding ElementName=slider_Fan_Speed_3, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="%" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Speed_3" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Temp_3" Text="{Binding ElementName=slider_Fan_Temp_3, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="°C" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Temp_3" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Width="280" Margin="5" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan Curve 5" FontSize="16" FontWeight="Medium"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_4_Speed_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Margin="5,0,0,0" x:Name="textblock_Fan_Curve_4_Temp_Value" Foreground="{StaticResource ApplicationDimGrayBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Speed_4" Text="{Binding ElementName=slider_Fan_Speed_4, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="%" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Speed_4" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="textbox_Fan_Temp_4" Text="{Binding ElementName=slider_Fan_Temp_4, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                            <TextBlock Grid.Column="1" Width="20" Text="°C" TextAlignment="Center" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            <Slider Grid.Column="2" x:Name="slider_Fan_Temp_4" ValueChanged="slider_Fan_ValueChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </VariableSizedWrapGrid>
                        </StackPanel>

                        <!-- Display -->
                        <StackPanel x:Name="stackpanel_Display" Visibility="Collapsed">
                            <TextBlock Text="HDR Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- High Dynamic Range -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Enable High Dynamic Range for the display to enable a wider range of colors to improve visual quality."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting requires a High Dynamic Range compatible monitor."/>
                                        <ToggleSwitch x:Name="toggleswitch_HdrEnable" Margin="10,0,0,0" OffContent="High Dynamic Range" OnContent="High Dynamic Range" Toggled="toggleswitch_HdrEnable_Toggled"/>
                                    </StackPanel>

                                    <!-- HDR Media Profile -->
                                    <StackPanel x:Name="stackpanel_Display_HdrTypePreference">
                                        <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>
                                        <StackPanel Margin="0,10,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Change the display HDR Media Profile for optimal color accuracy when viewing HDR content."/>
                                                <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting requires an AMD FreeSync Premium Pro compatible monitor."/>
                                                <TextBlock Text="HDR Media Profile" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ComboBox x:Name="combobox_Display_HdrTypePreference" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_HdrTypePreference_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="FreeSync Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- FreeSync -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="AMD FreeSync technology synchronizes the refresh rate of a display with the framerate to deliver dynamic refresh rate.&#10;&#10;AMD FreeSync technology reduces or eliminates visual artifacts, input latency, screen tearing and stuttering during gaming and video playback."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This setting requires an AMD FreeSync compatible monitor and graphics card."/>
                                        <ToggleSwitch x:Name="toggleswitch_FreeSync" Margin="10,0,0,0" OffContent="AMD FreeSync" OnContent="AMD FreeSync" Toggled="toggleswitch_FreeSync_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="Scaling Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Virtual Super Resolution -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Virtual Super Resolution allows applications to render at resolutions higher than the display's native resolution and then scales the image down to match the display, producing higher quality visuals at the expense of performance.&#10;&#10;VSR is beneficial for games lacking anti-aliasing options or those with insufficient anti-aliasing, this is often seen in older gaming titles."/>
                                        <ToggleSwitch x:Name="toggleswitch_VSR" Margin="10,0,0,0" OffContent="AMD Virtual Super Resolution" OnContent="AMD Virtual Super Resolution" Toggled="toggleswitch_VSR_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- GPU Scaling -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="GPU scaling uses the GPU to scale up lower resolutions to fit the display.&#10;&#10;When not enabled, displays typically handle scaling themselves."/>
                                        <ToggleSwitch x:Name="toggleswitch_GPUScaling" Margin="10,0,0,0" OffContent="GPU Scaling" OnContent="GPU Scaling" Toggled="toggleswitch_GPUScaling_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Integer Scaling -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Integer Scaling gives a sharp, pixelated look to images scaled up to fit the display, images that can't be scaled to match the display's exact size and shape will be centered on screen.&#10;&#10;Integer Scaling enhances visuals in old games to revive vintage gaming experiences on a modern display."/>
                                        <ToggleSwitch x:Name="toggleswitch_IntegerScaling" Margin="10,0,0,0" OffContent="Integer Scaling" OnContent="Integer Scaling" Toggled="toggleswitch_IntegerScaling_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Scaling Mode -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Method used to stretch and position images to fit the display.&#10;&#10;- Preserve aspect ratio: Maintains the original aspect ratio of the image while fitting it to the display.&#10;&#10;- Full panel: Stretches image to fill the entire display.&#10;&#10;- Center: Centers image on the display keeping original aspect and pixel ratio."/>
                                            <TextBlock Text="Scaling Mode" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox x:Name="combobox_Display_ScalingMode" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_ScalingMode_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="Power Options" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Vari-Bright -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Vari-Bright saves power by adaptively adjusting the display brightness based on image content."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* This feature is only available on laptop's."/>
                                        <ToggleSwitch x:Name="toggleswitch_VariBright" Margin="10,0,0,0" OffContent="Vari-Bright" OnContent="Vari-Bright" Toggled="toggleswitch_VariBright_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Vari-Bright Level -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Vertical">
                                        <TextBlock Text="Vari-Bright Level" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="combobox_Display_VariBright_Level" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_VariBright_Level_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="Color Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Color Depth -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Color format to be used with your display."/>
                                            <TextBlock Text="Color Depth" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox x:Name="combobox_Display_ColorDepth" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_ColorDepth_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Pixel Format -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Pixel format used to encode images for the display."/>
                                            <TextBlock Text="Pixel Format" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox x:Name="combobox_Display_PixelFormat" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_PixelFormat_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Display Color Enhancement -->
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Built-in LUT profiles that improve clarity and color vibrance of displayed content.&#10;&#10;- Vivid Gaming: Enhances overall brightness and colorfulness.&#10;&#10;- Dynamic Contrast: Improves visibility of dimmed details."/>
                                            <TextBlock Text="Display Color Enhancement" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox x:Name="combobox_Display_DisplayColorEnhancement" Margin="0,5,0,0" Width="300" SelectionChanged="combobox_Display_DisplayColorEnhancement_SelectionChanged" Style="{ThemeResource ApplicationComboBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Custom Color -->
                            <TextBlock Text="Custom Color" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Brightness -->
                                    <TextBlock Text="Brightness"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Brightness" Text="{Binding ElementName=slider_Display_Brightness, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Brightness" Margin="10,0,0,0" ValueChanged="slider_Display_Brightness_ValueChanged"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Contrast -->
                                    <TextBlock Text="Contrast" Margin="0,5,0,0"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Contrast" Text="{Binding ElementName=slider_Display_Contrast, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Contrast" Margin="10,0,0,0" ValueChanged="slider_Display_Contrast_ValueChanged"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Saturation -->
                                    <TextBlock Text="Saturation" Margin="0,5,0,0"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Saturation" Text="{Binding ElementName=slider_Display_Saturation, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Saturation" Margin="10,0,0,0" ValueChanged="slider_Display_Saturation_ValueChanged"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Hue -->
                                    <TextBlock Text="Hue" Margin="0,5,0,0"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Hue" Text="{Binding ElementName=slider_Display_Hue, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Hue" Margin="10,0,0,0" ValueChanged="slider_Display_Hue_ValueChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Color Temperature -->
                            <TextBlock Text="Color Temperature" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Control -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Enable or disable color temperature control."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* When 'Color Temperature Control' is disabled your colors will be limited to a narrow color gamut which may lead to oversaturated and incorrect color accuracy on HDR enabled displays."/>
                                        <ToggleSwitch x:Name="toggleswitch_Display_ColorTemperature_Control" Margin="10,0,0,0" OffContent="Color Temperature Control" OnContent="Color Temperature Control" Toggled="toggleswitch_Display_ColorTemperature_Control_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Kelvin -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Choose how warm or cool images will look on your display."/>
                                        <TextBlock Text="Color Temperature Kelvin" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_ColorTemperature" Text="{Binding ElementName=slider_Display_ColorTemperature_Kelvin, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_ColorTemperature_Kelvin" Margin="10,0,0,0" ValueChanged="slider_Display_ColorTemperature_Kelvin_ValueChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Color Deficiency Correction -->
                            <TextBlock Text="Color Deficiency Correction" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>

                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Control -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Enable or disable accessibility mode that allows tweaking of colors for users who experience varying levels of color vision deficiency."/>
                                        <ToggleSwitch x:Name="toggleswitch_Display_CVDC_Control" Margin="10,0,0,0" OffContent="Color Deficiency Correction Control" OnContent="Color Deficiency Correction Control" Toggled="toggleswitch_Display_CVDC_Control_Toggled"/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Protanopia -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjustments for red color blindness."/>
                                        <TextBlock Text="Protanopia Correction" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Protanopia" Text="{Binding ElementName=slider_Display_Protanopia, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Protanopia" Margin="10,0,0,0" ValueChanged="slider_Display_Protanopia_ValueChanged"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Deuteranopia -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjustments for green color blindness."/>
                                        <TextBlock Text="Deuteranopia Correction" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Deuteranopia" Text="{Binding ElementName=slider_Display_Deuteranopia, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Deuteranopia" Margin="10,0,0,0" ValueChanged="slider_Display_Deuteranopia_ValueChanged"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Tritanopia -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Adjustments for blue color blindness."/>
                                        <TextBlock Text="Tritanopia Correction" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="textbox_Display_Tritanopia" Text="{Binding ElementName=slider_Display_Tritanopia, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Display_Tritanopia" Margin="10,0,0,0" ValueChanged="slider_Display_Tritanopia_ValueChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Overrides -->
                            <TextBlock Text="Overrides" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>

                            <!-- HDCP Support -->
                            <Border Margin="0,5,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="If High-bandwidth Digital Content Protection (HDCP) is disabled on this display, digitally protected content may be unplayable, or played at a lower resolution."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* System restart required to take effect."/>
                                        <ToggleSwitch x:Name="toggleswitch_HDCPSupport" Margin="10,0,0,0" OffContent="HDCP Support" OnContent="HDCP Support" Toggled="toggleswitch_HDCPSupport_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Eyefinity -->
                            <TextBlock Text="Eyefinity" Margin="0,10,0,0" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <!-- Buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Eyefinity allows you to combine multiple displays to act as one big screen."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* Eyefinity only works when multiple displays are connected, turned on and needs to be in Duplicate or Extended display mode.&#10;&#10;* Eyefinity needs to be enabled to be able to remove configurations."/>
                                        <Button x:Name="button_Eyefinity_CreateCustom" Content="Create Eyefinity" Click="button_Eyefinity_Create_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Create configuration and enable Eyefinity based on settings below."/>
                                        <Button x:Name="button_Eyefinity_DeleteAll" Content="Remove Eyefinity" Click="button_Eyefinity_Remove_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Remove configuration and disable Eyefinity."/>
                                        <Button x:Name="button_Eyefinity_Enable" Content="Enable Eyefinity" Click="button_Eyefinity_Enable_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Enable Eyefinity when it is inactive."/>
                                        <Button x:Name="button_Eyefinity_Disable" Content="Disable Eyefinity" Click="button_Eyefinity_Disable_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Disable Eyefinity when it is active."/>
                                    </StackPanel>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Rows -->
                                    <TextBlock Text="Horizontal displays" Margin="0,10,0,0" VerticalAlignment="Center"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ElementName=slider_Eyefinity_Rows, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Eyefinity_Rows" Margin="10,0,0,0" Minimum="1" Maximum="6"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Columns -->
                                    <TextBlock Text="Vertical displays" Margin="0,10,0,0" VerticalAlignment="Center"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ElementName=slider_Eyefinity_Columns, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider Grid.Column="1" x:Name="slider_Eyefinity_Columns" Margin="10,0,0,0" Minimum="1" Maximum="6"/>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Display Placement Order -->
                                    <TextBlock Text="Display Placement Order" Margin="0,10,0,0" VerticalAlignment="Center"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0" Source="/Assets/DragDrop.png" Width="30" Height="30" ToolTipService.ToolTip="Drag and drop displays in the order you want them to be, from left to right and top to bottom."/>
                                        <ListView Grid.Column="1" x:Name="listview_EyefinityMonitorIndex" Margin="5,0,0,0" Height="40" CanReorderItems="True" CanDragItems="True" AllowDrop="True">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="local:DisplayDetailsIdl">
                                                    <Border CornerRadius="4" BorderThickness="2" BorderBrush="{ThemeResource ApplicationDimGrayColor}" Margin="-10">
                                                        <TextBlock Text="{x:Bind Name}" HorizontalAlignment="Center" Margin="5"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Display Orientation -->
                                    <TextBlock Text="Display Orientation" Margin="0,10,0,0" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="combobox_EyefinityMonitorOrientation" Margin="0,5,0,0" Width="300" Style="{ThemeResource ApplicationComboBox}"/>

                                    <Border Margin="0,10,0,0" CornerRadius="2" Height="2" Background="{StaticResource ApplicationDarkGrayBrush}" Opacity="0.20"/>

                                    <!-- Automatic Eyefinity -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="When you add an application to the list below Eyefinity will automatically be enabled when an application is running and disabled when no longer running."/>
                                        <Image Source="/Assets/Warning.png" Width="24" Height="24" ToolTipService.ToolTip="* It may take a few seconds before Eyefinity is activated when launching an application.&#10;&#10;* Automatic Eyefinity only works when RadeonTuner is running."/>
                                        <ToggleSwitch x:Name="toggleswitch_Eyefinity_Automatic" Margin="10,0,0,0" OffContent="Automatic Eyefinity" OnContent="Automatic Eyefinity" Toggled="toggleswitch_Eyefinity_Automatic_Toggled"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <ComboBox x:Name="combobox_Eyefinity_Applications" Width="300" Style="{ThemeResource ApplicationComboBox}"/>
                                        <Button x:Name="button_Eyefinity_AddExe" Content="Add executable" Click="button_Eyefinity_AppAddExe_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Add executable file as application."/>
                                        <Button x:Name="button_Eyefinity_Remove" Content="Remove" Click="button_Eyefinity_AppRemove_Click" Margin="10,0,0,0" Style="{ThemeResource ApplicationButton}" ToolTipService.ToolTip="Remove selected application."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Multimedia -->
                        <StackPanel x:Name="stackpanel_Multimedia" Visibility="Collapsed">
                            <TextBlock Text="Video Options" FontSize="20" FontWeight="Medium"/>

                            <!-- Video Sharpening -->
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Video Sharpening improves video playback quality by sharpening the video."/>
                                        <ToggleSwitch x:Name="toggleswitch_Video_Sharpening" Margin="10,0,0,0" OffContent="Video Sharpening" OnContent="Video Sharpening" Toggled="toggleswitch_Video_Sharpening_Toggled"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Sharpening" VerticalAlignment="Center"/>
                                        <TextBox x:Name="textbox_VideoUpscale_Sharpening" Margin="5,0,0,0" Text="{Binding ElementName=slider_Video_Sharpening, Path=Value}" Style="{ThemeResource ApplicationTextBoxReadOnly}"/>
                                        <Slider x:Name="slider_Video_Sharpening" Width="150" Margin="10,0,10,0" ValueChanged="slider_Video_Sharpening_ValueChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Settings -->
                        <StackPanel x:Name="stackpanel_Settings" Visibility="Collapsed">
                            <TextBlock Text="Launch Settings" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Launch RadeonTuner on Windows startup automatically."/>
                                        <ToggleSwitch x:Name="toggleswitch_Shortcut_Startup" Margin="10,0,0,0" OffContent="Launch on Windows startup" OnContent="Launch on Windows startup" Toggled="toggleswitch_Shortcut_Startup_Toggled"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Add RadeonTuner shortcut to the start menu application list."/>
                                        <ToggleSwitch x:Name="toggleswitch_Shortcut_StartMenu" Margin="10,0,0,0" OffContent="Add application to start menu" OnContent="Add application to start menu" Toggled="toggleswitch_Shortcut_StartMenu_Toggled"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Add RadeonTuner to the Windows desktop context (right click) menu."/>
                                        <Image x:Name="toggleswitch_Shortcut_ContextMenu_AdminShield" Source="/Assets/Shield.png" Width="24" Height="24" ToolTipService.ToolTip="Changing this setting requires administrator access."/>
                                        <ToggleSwitch x:Name="toggleswitch_Shortcut_ContextMenu" Margin="10,0,0,0" OffContent="Add application to context menu" OnContent="Add application to context menu" Toggled="toggleswitch_Shortcut_ContextMenu_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Window Settings" FontSize="20" FontWeight="Medium" Margin="0,10,0,0"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Show settings window when lauching this application."/>
                                        <ToggleSwitch x:Name="toggleswitch_StartWindowVisible" Margin="10,0,0,0" OffContent="Show window on startup" OnContent="Show window on startup" Toggled="toggleswitch_StartWindowVisible_Toggled"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Show this window on top of other applications."/>
                                        <ToggleSwitch x:Name="toggleswitch_Window_Top" Margin="10,0,0,0" OffContent="Show window on top" OnContent="Show window on top" Toggled="toggleswitch_Window_Top_Toggled"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Close application to system tray menu instead of exiting."/>
                                        <ToggleSwitch x:Name="toggleswitch_Close_Tray" Margin="10,0,0,0" OffContent="Close to system tray" OnContent="Close to system tray" Toggled="toggleswitch_Close_Tray_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Experimental Settings" FontSize="20" FontWeight="Medium" Margin="0,10,0,0"/>
                            <Border Margin="0,10,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Information.png" Width="24" Height="24" ToolTipService.ToolTip="Show experimental settings used for testing purposes."/>
                                        <ToggleSwitch x:Name="toggleswitch_ShowExperimental" Margin="10,0,0,0" OffContent="Show experimental settings" OnContent="Show experimental settings" Toggled="toggleswitch_ShowExperimental_Toggled"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Information -->
                        <StackPanel x:Name="stackpanel_Information" Visibility="Collapsed">
                            <TextBlock Text="GPU Information" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,5,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <TextBlock x:Name="textblock_GpuInfo" Text="..."/>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="Display Information" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,5,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <TextBlock x:Name="textblock_DisplayInfo" Text="..."/>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0" Text="Application Information" FontSize="20" FontWeight="Medium"/>
                            <Border Margin="0,5,0,0" Padding="5" CornerRadius="8" Background="{ThemeResource ApplicationVoidGrayColor}">
                                <StackPanel>
                                    <TextBlock x:Name="textblock_AppInfo" Text="..."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Overlay -->
        <Grid x:Name="grid_Overlay" Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="{ThemeResource ApplicationBlackColor}" Opacity="0.90"/>
            </Grid.Background>
            <StackPanel Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="textblock_Overlay_Text" Text="..." TextWrapping="Wrap" FontSize="40" TextAlignment="Center" Foreground="{ThemeResource ApplicationWhiteColor}"/>
                <TextBlock x:Name="textblock_Overlay_Sub_Text" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="24" TextAlignment="Center" Foreground="{ThemeResource ApplicationDimGrayColor}"/>
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Button x:Name="button_Overlay_DriverCleanup" Click="button_Overlay_DriverCleanup_Click" Content="Run AMD Cleanup Utility" HorizontalAlignment="Center" Style="{ThemeResource ApplicationButton}"/>
                    <Button x:Name="button_Overlay_Exit" Margin="20,00,0,0" Click="button_Overlay_Exit_Click" Content="Exit Application" HorizontalAlignment="Center" Style="{ThemeResource ApplicationButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Notification -->
        <Border x:Name="grid_Notification" Margin="0,114,5,0" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed" IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="{ThemeResource ApplicationAccentDimColor}" Opacity="0.90"/>
            </Border.Background>
            <StackPanel Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="textblock_Notification_Text" Text="..." TextWrapping="Wrap" FontSize="20" TextAlignment="Center" Foreground="{ThemeResource ApplicationWhiteColor}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>